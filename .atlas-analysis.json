  "keyFeatures": [
    "Self-hosted deployment with full data sovereignty",
    "Collaborative wiki and knowledge base (Collabase Docs)",
    "Quality assurance suite with test projects, cases, and runs (Test Management)",
    "Visual no-code workflow builder (Automation)",
    "Internal communication hub with announcements and blog feed (Intranet)",
    "RBAC with global and space-level roles",
    "Unified full-text search across all content",
    "Local AI integration via Ollama and support for OpenAI, Anthropic, Azure, and Google",
    "SAML and LDAP identity provider support",
    "SCIM v2 user provisioning",
    "GDPR compliant, 100% Swiss hosted",
    "Docker-based one-command installation"
  ],
  "publicApiSurface": [
    "POST /api/v1/pages — Create a page",
    "GET /api/v1/automation — List automations",
    "POST /api/v1/automation/:id/trigger — Trigger an automation",
    "GET /api/v1/test-management/projects — List test projects",
    "POST /api/v1/test-management/projects — Create a test project",
    "POST /api/v1/test-management/cases — Create a test case",
    "POST /api/v1/test-management/runs — Create a test run",
    "GET /api/v1/spaces — List spaces",
    "SCIM v2 /api/scim/v2/Users — User provisioning",
    "SCIM v2 /api/scim/v2/Groups — Group provisioning"
  ]
